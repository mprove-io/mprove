{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "autoupdate": false,
  "server": {
    "hostname": "opencode.local",
    "port": 4096
  },
  "permission": {
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "/mprove/.env": "deny",
      "/mprove/.envrc": "deny",
      "/mprove/secrets/*": "deny",
      "/mprove/_nogit/*": "deny"
    },
    "edit": {
      "_nogit/*": "deny",
      "external/*": "deny",
      "secrets/*": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      //
      "/mprove/_nogit/*": "deny",
      "/mprove/external/*": "deny",
      "/mprove/secrets/*": "deny",
      "/mprove/.env": "deny",
      "/mprove/.env.*": "deny",
      "/mprove/.envrc": "deny"
    }
  }
}
