{
  "name": "@mprove/blockml",
  "version": "12.0.4",
  "private": true,
  "type": "module",
  "imports": {
    "#blockml/*": "./src/*",
    "#common/*": "@mprove/common/*",
    "#node-common/*": "@mprove/node-common/*"
  },
  "scripts": {
    "check": "pnpm typecheck && pnpm lint",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "biome lint src",
    "circular": "madge --circular .",
    "build": "swc src -d dist --source-maps && node build.mjs",
    "node-serve": "dotenv -e ../../.env -- node --enable-source-maps --disable-warning=DEP0169 dist/main.js",
    "start": "dotenv -e ../../.env -v SWC_NODE_PROJECT=tsconfig.app.json -- node --import @swc-node/register/esm-register --disable-warning=DEP0169 --watch src/main.ts",
    "debug": "dotenv -e ../../.env -v SWC_NODE_PROJECT=tsconfig.app.json -- node --import @swc-node/register/esm-register --disable-warning=DEP0169 --inspect=0.0.0.0:9231 --watch src/main.ts",
    "compile-test": "rimraf dist-test && node compile-test.mjs",
    "test": "pnpm compile-test && dotenv -e ../../.env -v BLOCKML_LOG_IO=TRUE -v IS_TELEMETRY_ENABLED=FALSE -- ava --config ava.compiled.config.js --concurrency=6",
    "clean-node": "rimraf --glob \"node_modules/*\" \"node_modules/.[!.]*\"",
    "clean-dist": "rimraf --glob \"dist/*\" \"dist/.[!.]*\"",
    "clean-turbo": "rimraf --glob \".turbo/*\" \".turbo/.[!.]*\""
  },
  "dependencies": {
    "@codemirror/language": "catalog:",
    "@codemirror/state": "catalog:",
    "@codemirror/view": "catalog:",
    "@lezer/highlight": "catalog:",
    "@malloydata/db-bigquery": "catalog:",
    "@malloydata/db-databricks": "catalog:",
    "@malloydata/db-duckdb": "catalog:",
    "@malloydata/db-mysql": "catalog:",
    "@malloydata/db-postgres": "catalog:",
    "@malloydata/db-snowflake": "catalog:",
    "@malloydata/db-trino": "catalog:",
    "@malloydata/malloy": "catalog:",
    "@malloydata/malloy-filter": "catalog:",
    "@malloydata/malloy-interfaces": "catalog:",
    "@malloydata/malloy-query-builder": "catalog:",
    "@malloydata/malloy-tag": "catalog:",
    "@mprove/common": "workspace:*",
    "@mprove/node-common": "workspace:*",
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/throttler": "catalog:",
    "@opencode-ai/sdk": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/auto-instrumentations-node": "catalog:",
    "@opentelemetry/exporter-trace-otlp-http": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-node": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "@replit/codemirror-indentation-markers": "catalog:",
    "@vaadin/date-picker": "catalog:",
    "bcrypt": "catalog:",
    "d3-format": "catalog:",
    "date-fns": "catalog:",
    "date-fns-tz": "catalog:",
    "dayjs": "catalog:",
    "fs-extra": "catalog:",
    "groupmq": "catalog:",
    "ioredis": "catalog:",
    "ipaddr.js": "catalog:",
    "js-yaml": "catalog:",
    "nanoid": "catalog:",
    "neoip": "catalog:",
    "nest-winston": "catalog:",
    "p-iteration": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "simple-git": "catalog:",
    "tiny-async-pool": "catalog:",
    "trino-client": "catalog:",
    "tslib": "catalog:",
    "walk": "catalog:",
    "winston": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nestjs/testing": "catalog:",
    "@swc-node/register": "catalog:",
    "@swc/cli": "catalog:",
    "@swc/core": "catalog:",
    "@swc/helpers": "catalog:",
    "@types/d3-format": "catalog:",
    "@types/fs-extra": "catalog:",
    "@types/js-yaml": "catalog:",
    "@types/tiny-async-pool": "catalog:",
    "@types/walk": "catalog:",
    "ava": "catalog:",
    "dotenv-cli": "catalog:",
    "esbuild": "catalog:"
  }
}
